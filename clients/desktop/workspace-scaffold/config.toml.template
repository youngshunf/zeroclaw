# ═══════════════════════════════════════════════════════════════
# 唤星桌面端 — Agent 配置
# 由唤星桌面端自动生成
# 生成时间: {{timestamp}}
# ═══════════════════════════════════════════════════════════════

display_name = "{{star_name}}"

# ── LLM Provider ──────────────────────────────────────────────
api_key = "{{llm_token}}"
default_provider = "custom:{{llm_gateway_base}}"
default_model = "claude-sonnet-4-6"
title_model = "claude-haiku-4-5"   # 会话标题自动生成用的轻量模型
default_temperature = 0.7

# ── Agent 核心设置 ────────────────────────────────────────────
[agent]
compact_context = false          # 用大模型，不需要压缩模式
max_tool_iterations = 15
max_history_messages = 100       # 100条后才触发压缩

[agent.session]
backend = "sqlite"               # 持久化！重启不丢失
strategy = "per-sender"          # 每用户独立会话
ttl_seconds = 604800             # 7天 — 用户一周内回来不断层
max_messages = 100               # 每会话保留100条消息

# ── 记忆 ──────────────────────────────────────────────────────
[memory]
backend = "sqlite"
auto_save = true                 # 自动保存对话到长期记忆
hygiene_enabled = true           # 定期清理
archive_after_days = 14          # 14天后归档
purge_after_days = 90            # 90天后清除
conversation_retention_days = 90 # 对话记录保留90天
auto_hydrate = true              # brain.db丢失时自动恢复
snapshot_enabled = true          # 启用记忆快照备份
snapshot_on_hygiene = true       # 清理时自动快照

# ── 向量记忆（语义搜索） ──────────────────────────────────────
embedding_provider = "custom:{{llm_gateway_base}}"
embedding_model = "text-embedding-v4"
embedding_dimensions = 1024      # 通义 text-embedding-v4 输出维度
vector_weight = 0.7              # 向量相似度权重
keyword_weight = 0.3             # BM25 关键词权重
min_relevance_score = 0.4        # 最低相关性阈值
embedding_cache_size = 2000      # 缓存大小
chunk_max_tokens = 512           # 每块最大 token 数

# ── 自治与安全 ────────────────────────────────────────────────
[autonomy]
level = "full"
workspace_only = true
allowed_commands = [
    # 信息查询
    "ls", "cat", "head", "tail", "wc", "grep", "find",
    "echo", "pwd", "date",
    # 文本处理
    "sort", "uniq", "tr", "cut", "awk", "sed",
    # 文件管理
    "mkdir", "touch", "cp", "mv",
]
forbidden_paths = [
    "/etc", "/root", "/home", "/usr", "/bin", "/sbin",
    "/lib", "/opt", "/boot", "/dev", "/proc", "/sys",
    "/var", "/tmp", "/mnt",
    "~/.ssh", "~/.gnupg", "~/.aws", "~/.config",
]
max_actions_per_hour = 200
max_cost_per_day_cents = 1000
block_high_risk_commands = true
auto_approve = [
    "file_read", "file_write", "file_create",
    "memory_recall", "memory_store",
    "glob_search", "content_search",
    "shell", "process",
    "cron_add", "cron_list", "cron_remove", "cron_update",
    "web_search", "web_fetch",
    "browser", "browser_open",
    "hasn_send", "hasn_contacts", "hasn_add_friend", "hasn_inbox",
    "hx_lookup_sender", "hx_get_user", "hx_check_quota",
    "hx_usage_stats", "hx_get_subscription",
    "hx_doc_list", "hx_doc_get", "hx_doc_create", "hx_doc_update",
]
# 排除危险工具，保留实用工具
non_cli_excluded_tools = []

# ── 安全 ──────────────────────────────────────────────────────
[security]
canary_tokens = true
semantic_guard = false

[security.otp]
enabled = false

[security.outbound_leak_guard]
enabled = true
action = "redact"
sensitivity = 0.7

# ── Gateway ───────────────────────────────────────────────────
[gateway]
port = {{port}}
host = "127.0.0.1"
require_pairing = false

# ── Cron ──────────────────────────────────────────────────────
[cron]
enabled = true
max_run_history = 20

# ── Heartbeat ─────────────────────────────────────────────────
[heartbeat]
enabled = true
interval_minutes = 60            # 1小时一次
max_tasks_per_tick = 2

# ── 多模态 ────────────────────────────────────────────────────
[multimodal]
max_images = 4
max_image_size_mb = 5
allow_remote_fetch = false

# ── 开放功能 ──────────────────────────────────────────────────
[web_search]
enabled = true

[web_fetch]
enabled = true

[browser]
enabled = true

# ── 身份 ──────────────────────────────────────────────────────
[identity]
format = "openclaw"

# ── 唤星平台 ──────────────────────────────────────────────────
[huanxing]
enabled = true
api_base_url = "{{api_base}}"

[huanxing.templates]

# ── 禁用功能 ──────────────────────────────────────────────────
[http_request]
enabled = false

[proxy]
enabled = false

[composio]
enabled = false

[mcp]
enabled = false

[wasm]
enabled = false

[plugins]
enabled = false

[channels_config]
cli = false
message_timeout_secs = 300

# ── 其他 ──────────────────────────────────────────────────────
[scheduler]
enabled = true

[skills]
open_skills_enabled = false

[reliability]
provider_retries = 2

[runtime]
kind = "native"

[observability]
backend = "none"
