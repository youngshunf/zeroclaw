# ═══════════════════════════════════════════════════════════════
# 唤星AI - 租户级 Owner 配置模板
# 创建租户根目录时自动生成，保存租户/全局级的共同规则
# ═══════════════════════════════════════════════════════════════

# ── LLM Provider (租户默认) ──────────────────────────────────
# Desktop 模式下，这里的 api_key 允许为空。
# 运行时会优先读取租户/Agent 覆盖；若为空，则回退到 ~/.huanxing/config.toml 的全局 api_key。
# 只有云端部署或租户需要单独覆写时，才在这里写入真实值。
default_provider = "{{default_provider}}"
default_model = "{{default_model}}"
title_model = "{{title_model}}"
default_temperature = {{default_temperature}}
api_key = "{{api_key}}"

# ── 用户级 API 认证 ──────────────────────────────────────────
# HASN Owner API Key（hasn_ok_xxx），用于文档、云函数等用户级 API 认证。
# 注册时由后端自动签发并回写，无需手动配置。
owner_key = ""

# ── 向量记忆池 (租户共享配置) ────────────────────────────────
[memory]
embedding_provider = "{{embedding_provider}}"
embedding_model = "text-embedding-v4"
embedding_dimensions = 1024      # 通义 text-embedding-v4 输出维度
vector_weight = 0.7              # 向量相似度权重
keyword_weight = 0.3             # BM25 关键词权重
min_relevance_score = 0.4        # 最低相关性阈值
embedding_cache_size = 2000      # 缓存大小
chunk_max_tokens = 512           # 每块最大 token 数

# ┌─────────────────────────────────────────────────────────────┐
# │                    可靠性（LLM 重试/降级）                    │
# └─────────────────────────────────────────────────────────────┘
[reliability]
provider_retries = 5                         # 单个 provider 最多重试次数
provider_backoff_ms = 500                     # 重试退避时间
fallback_providers = ["{{fallback_provider}}"]  # 降级到 openai compat 格式
# api_keys 留空 —— 代码会自动将 api_key 注入（租户级自动透传）
api_keys = []
channel_initial_backoff_secs = 2              # 渠道连接初始退避
channel_max_backoff_secs = 60                 # 渠道连接最大退避
scheduler_poll_secs = 15
scheduler_retries = 2

# ══════════════════════════════════════════════════════════════
# 自治与安全 (租户全局)
# ══════════════════════════════════════════════════════════════
[autonomy]
level = "full"                   # full = 所有工具自动批准，无需人工确认
workspace_only = false            # ⚠️ 多租户安全：只能访问自己的工作区

# ── Shell 命令白名单 ──
allowed_commands = []


# ── 禁止访问的系统路径 ──
forbidden_paths = []

max_actions_per_hour = 200
max_cost_per_day_cents = 1000
block_high_risk_commands = true

# ── 对用户 Agent 隐藏的系统工具（不在 CLI 通道对大模型可见）──
non_cli_excluded_tools = [
    # ═══ 服务器管理 & 用户注册（Guardian 专用）═══
    "hx_register_user",          # 注册新用户
    "hx_send_sms",               # 发送短信验证码
    "hx_verify_sms",             # 验证短信
    "hx_lookup_sender",          # 查找发送者身份
    "hx_get_user",               # 获取用户信息
    "hx_local_find_user",        # 本地查找用户
    "hx_local_bind_channel",     # 绑定渠道
    "hx_local_list_users",       # 列出所有用户
    "hx_local_update_user",      # 更新用户信息
    "hx_local_stats",            # 服务器统计
    "hx_invalidate_cache",       # 缓存失效
]

# ── 安全机制 ──────────────────────────────────────────────────
[security]
canary_tokens = true
semantic_guard = false

[security.otp]
enabled = false

[security.outbound_leak_guard]
enabled = true
action = "redact"
sensitivity = 0.5

# ── 语音合成 (TTS) ────────────────────────────────────────────
[tts]
enabled = true
default_provider = "generic_openai"
default_voice = "Cherry"
default_format = "wav"

[tts.generic_openai]
api_url = "{{llm_gateway}}/audio/speech"
model = "qwen3-tts-instruct-flash"

# ── 语音识别 (STT) ────────────────────────────────────────────
[transcription]
enabled = true
default_provider = "groq"
api_url = "{{llm_gateway}}/audio/transcriptions"
model = "qwen3-asr-flash-2026-02-10"

# ══════════════════════════════════════════════════════════════
# 平台级功能开关
# ══════════════════════════════════════════════════════════════
[web_search]
enabled = true

[web_fetch]
enabled = true

[browser]
enabled = true

[http_request]
enabled = true

[proxy]
enabled = false

[composio]
enabled = false

[mcp]
enabled = false

[wasm]
enabled = false

[plugins]
enabled = false

# ── 渠道超时 ──────────────────────────────────────────────────
[channels_config]
cli = false
message_timeout_secs = 300
