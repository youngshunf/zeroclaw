# ═══════════════════════════════════════════════════════════════
# 唤星AI - 工作区 Agent 配置模板
# 创建 Agent 时自动复制，只替换 {{...}} 占位符
# ═══════════════════════════════════════════════════════════════

# ── agent级独立配置 ──────────────────────────────
display_name = "星源"
default_model = "{{default_model}}"
default_temperature = 0.7

# ── Agent 核心设置 ────────────────────────────────────────────
[agent]
name = "{{agent_id}}"
template = "{{template}}"
# Desktop onboard 只创建本地 Agent 壳。
# hasn_id 会在登录后的 HASN 注册成功后回写，因此首次生成时为空是预期行为。
hasn_id = "{{hasn_id}}"
compact_context = true          # 用大模型，不需要压缩模式
max_tool_iterations = 50
max_history_messages = 100       # 100条后才触发压缩
