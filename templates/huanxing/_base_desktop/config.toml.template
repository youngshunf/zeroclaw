# ═══════════════════════════════════════════════════════════════
# 唤星桌面端 — Agent 工作区配置
# 由桌面端 Agent 管理器自动生成
# ═══════════════════════════════════════════════════════════════
#
# 注意：LLM 凭据（api_key / default_provider）从全局 config.toml 继承，
# 此处不写，避免多个 Agent 各自维护冗余的 key 副本。

display_name = "{{star_name}}"
default_model = "{{default_model}}"
default_temperature = {{default_temperature}}

# ── Agent 核心设置 ────────────────────────────────────────────
[agent]
compact_context = false
max_tool_iterations = 15
max_history_messages = 100

[agent.session]
backend = "sqlite"
strategy = "per-sender"
ttl_seconds = 604800             # 7天
max_messages = 200

# ── 记忆 ──────────────────────────────────────────────────────
[memory]
backend = "sqlite"
auto_save = true
hygiene_enabled = true
archive_after_days = 14
purge_after_days = 90
conversation_retention_days = 90
auto_hydrate = true
snapshot_enabled = true
snapshot_on_hygiene = true

# ── 自治与安全 ────────────────────────────────────────────────
[autonomy]
level = "full"
workspace_only = true
allowed_commands = [
    "ls", "cat", "head", "tail", "wc", "grep", "find",
    "echo", "pwd", "date",
    "sort", "uniq", "tr", "cut", "awk", "sed",
    "mkdir", "touch", "cp", "mv",
]
forbidden_paths = [
    "/etc", "/root", "/home", "/usr", "/bin", "/sbin",
    "/lib", "/opt", "/boot", "/dev", "/proc", "/sys",
    "/var", "/tmp", "/mnt",
    "~/.ssh", "~/.gnupg", "~/.aws",
]
max_actions_per_hour = 500
block_high_risk_commands = true
auto_approve = [
    "file_read", "file_write", "file_create", "file_edit",
    "memory_recall", "memory_store",
    "glob_search", "content_search",
    "shell", "process",
    "cron_add", "cron_list", "cron_remove", "cron_update",
    "web_search", "web_fetch",
    "browser", "browser_open",
    "hasn_send", "hasn_contacts", "hasn_add_friend", "hasn_inbox",
    "hx_lookup_sender", "hx_get_user", "hx_check_quota",
    "hx_usage_stats", "hx_get_subscription",
    "hx_doc_list", "hx_doc_get", "hx_doc_create", "hx_doc_update",
]
non_cli_excluded_tools = [
    "http_request",
    "proxy_config", "web_search_config", "web_access_config",
    "model_routing_config", "channel_ack_config", "quota_tools",
    "composio", "delegate",
    "screenshot", "image_info",
]

# ── 安全 ──────────────────────────────────────────────────────
[security]
canary_tokens = true
semantic_guard = false

[security.otp]
enabled = false

[security.outbound_leak_guard]
enabled = true
action = "redact"
sensitivity = 0.7

# ── Cron ──────────────────────────────────────────────────────
[cron]
enabled = true
max_run_history = 20

# ── Heartbeat ─────────────────────────────────────────────────
[heartbeat]
enabled = true
interval_minutes = 60
max_tasks_per_tick = 2

# ── 多模态 ────────────────────────────────────────────────────
[multimodal]
max_images = 4
max_image_size_mb = 5
allow_remote_fetch = false

# ── 开放功能 ──────────────────────────────────────────────────
[web_search]
enabled = true

[web_fetch]
enabled = true

[browser]
enabled = true

# ── 禁用功能 ──────────────────────────────────────────────────
[http_request]
enabled = false

[proxy]
enabled = false

[composio]
enabled = false

[mcp]
enabled = false

[wasm]
enabled = false

[plugins]
enabled = false

[channels_config]
cli = false
message_timeout_secs = 300

# ── 技能 ──────────────────────────────────────────────────────
[skills]
allow_scripts = true
prompt_injection_mode = "full"
