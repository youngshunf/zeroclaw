# ═══════════════════════════════════════════════════════════════
# ZeroClaw HuanXing 环境变量配置示例
# 路径: huanxing-zeroclaw/server-config/.env.example
#
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填入你的实际 API Keys
# 3. 重启 daemon：supervisorctl restart zeroclaw
# ═══════════════════════════════════════════════════════════════

# ── Web Search 配置 ────────────────────────────────────────────
# 网络搜索工具，支持多种供应商

WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECS=15

# ── 搜索供应商 API Keys ────────────────────────────────────────

# 1. DuckDuckGo（默认，免费）
# 获取方式：无需 API Key
# 国内可用性：⚠️ 需要代理（被墙）
# 特点：免费但可能被限流
# 官网：https://duckduckgo.com
# 配置：无需配置，直接使用

# 2. Brave Search
# 获取方式：https://brave.com/search/api → 注册 → API Keys
# 国内可用性：✅ 可用（需要代理访问官网注册）
# 价格：$5/月起（1000次免费）
# 特点：高质量搜索结果，速度快
# BRAVE_API_KEY=BSA-xxxxxxxxxxxxxx

# 3. Tavily（推荐用于 AI Agent）
# 获取方式：https://tavily.com → Sign Up → API Keys
# 国内可用性：✅ 可用（API 端点国内可访问）
# 价格：免费 1000 次/月，付费 $20/月起
# 特点：专为 AI 优化，返回简洁相关内容
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxx

# 4. Firecrawl
# 获取方式：https://firecrawl.dev → Sign Up → API Keys
# 国内可用性：⚠️ 需要代理（官网被墙）
# 价格：免费 500 credits/月，付费 $20/月起
# 特点：网页抓取 + 搜索，支持自托管
# WEB_SEARCH_API_KEY=fc-xxxxxxxxxxxxxx
# WEB_SEARCH_API_URL=https://api.firecrawl.dev  # 可选，自托管时修改

# 5. Perplexity
# 获取方式：https://www.perplexity.ai/settings/api → 开通 API 访问
# 国内可用性：⚠️ 需要代理（被墙）
# 价格：按使用量计费
# 特点：AI 搜索引擎，结果质量高
# PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxx

# 6. Exa（神经网络搜索）
# 获取方式：https://exa.ai → Sign Up → API Keys
# 国内可用性：✅ 可用（API 端点国内可访问）
# 价格：免费 1000 次/月，付费 $20/月起
# 特点：神经网络搜索，语义理解强
# EXA_API_KEY=exa-xxxxxxxxxxxxxx
# WEB_SEARCH_EXA_SEARCH_TYPE=neural  # auto/keyword/neural
# WEB_SEARCH_EXA_INCLUDE_TEXT=true

# 7. Jina（免费但有限额）
# 获取方式：https://jina.ai → Sign Up → API Keys（可选）
# 国内可用性：✅ 可用（国内可访问）
# 价格：免费（有限额），API Key 可提升限额
# 特点：免费使用，适合测试
# JINA_API_KEY=jina-xxxxxxxxxxxxxx  # 可选

# ── 备用供应商配置 ──────────────────────────────────────────────
# 主供应商失败时自动切换到备用供应商

# 推荐配置 1：国内可用方案
# WEB_SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxx
# WEB_SEARCH_FALLBACK_PROVIDERS=exa,jina
# EXA_API_KEY=exa-xxxxxxxxxxxxxx

# 推荐配置 2：高质量方案（需要代理）
# WEB_SEARCH_PROVIDER=brave
# BRAVE_API_KEY=BSA-xxxxxxxxxxxxxx
# WEB_SEARCH_FALLBACK_PROVIDERS=tavily,perplexity,duckduckgo
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxx
# PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxx

# 推荐配置 3：免费方案
# WEB_SEARCH_PROVIDER=duckduckgo
# WEB_SEARCH_FALLBACK_PROVIDERS=jina
# 无需 API Key

# ── 高级配置 ────────────────────────────────────────────────────

# 重试配置
WEB_SEARCH_RETRIES_PER_PROVIDER=2
WEB_SEARCH_RETRY_BACKOFF_MS=250

# 过滤器
# WEB_SEARCH_DOMAIN_FILTER=github.com,stackoverflow.com
# WEB_SEARCH_LANGUAGE_FILTER=zh,en
# WEB_SEARCH_COUNTRY=CN
# WEB_SEARCH_RECENCY_FILTER=week  # day/week/month/year

# ── 多 Key 负载均衡 ─────────────────────────────────────────────
# 多个 Key 用逗号分隔，自动轮询

# BRAVE_API_KEY=BSA-key1,BSA-key2,BSA-key3
# TAVILY_API_KEY=tvly-key1,tvly-key2

# ── 其他技能 API Keys ───────────────────────────────────────────

# 天气查询（如果需要）
# WEATHER_API_KEY=xxxxxxxxxxxxxx

# 图片生成（如果需要）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxx  # 用于 DALL-E

# ═══════════════════════════════════════════════════════════════
# 国内可用性总结（2026-03）
# ═══════════════════════════════════════════════════════════════
#
# ✅ 国内直接可用（无需代理）：
#   - Tavily（推荐）
#   - Exa
#   - Jina
#
# ⚠️ 需要代理访问：
#   - DuckDuckGo（被墙）
#   - Brave（官网被墙，但 API 可能可用）
#   - Firecrawl（被墙）
#   - Perplexity（被墙）
#
# 💡 推荐国内配置：
#   WEB_SEARCH_PROVIDER=tavily
#   TAVILY_API_KEY=tvly-xxxxxxxxxxxxxx
#   WEB_SEARCH_FALLBACK_PROVIDERS=exa,jina
#   EXA_API_KEY=exa-xxxxxxxxxxxxxx
#
# ═══════════════════════════════════════════════════════════════
